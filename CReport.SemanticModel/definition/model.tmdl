model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Parameters

	annotation PBI_QueryGroupOrder = 0

queryGroup DataSource

	annotation PBI_QueryGroupOrder = 1

queryGroup Silver

	annotation PBI_QueryGroupOrder = 2

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["CSVs","DataFolder","Customer","Employee","Category","Invoice","Order","OrderStatus","OrderDetail","Product","Shipper","Supplier"]

annotation PBI_ProTooling = ["DevMode"]

ref table Customer
ref table Employee
ref table Category
ref table Invoice
ref table Order
ref table OrderStatus
ref table OrderDetail
ref table Product
ref table Shipper
ref table Supplier
ref table Date

ref cultureInfo en-US

