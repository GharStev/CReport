expression stg_Order = ```
		let
		    Source = CSVs,
		    Data = Source{[#"Folder Path"=DataFolder,Name="Orders.csv"]}[Content],
		    fnRealorExcelDate = (input) =>
		        let
		            // Try to convert standard text (mm/dd/yyyy) first
		            StandardDate = try DateTime.From(input, "en-US") otherwise null,
		            
		            // If that fails, try to convert from Excel Serial Number
		            ExcelDate = try DateTime.From(Number.From(input)) otherwise null,
		            
		            // Return the first one that actually worked
		            Result = if StandardDate <> null then StandardDate else ExcelDate
		        in
		            Result,
		    #"Imported CSV" = Csv.Document(Data,[Delimiter=",", Columns=4, Encoding=65001, QuoteStyle=QuoteStyle.None]),
		    #"Promoted Headers" = Table.PromoteHeaders(#"Imported CSV", [PromoteAllScalars=true]),
		    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"EmployeeID", Int64.Type}, {"PK_OrderID", Int64.Type}}),
		    #"Transformed OrderDate" = Table.TransformColumns(#"Changed Type", {
		        {"OrderDate", each fnRealorExcelDate(_), type date}
		    }),
		    #"Change Type (OrderDate) to Date" = Table.TransformColumnTypes(#"Transformed OrderDate",{{"OrderDate", type date}}),
		    #"Reordered Columns" = Table.ReorderColumns(#"Change Type (OrderDate) to Date",{"PK_OrderID", "CustomerID", "EmployeeID", "OrderDate"}),
		    #"Sorted Rows" = Table.Sort(#"Reordered Columns",{{"PK_OrderID", Order.Ascending}}),
		    #"Changed Type1" = Table.TransformColumnTypes(#"Sorted Rows",{{"PK_OrderID", type text}}),
		    #"Added Index" = Table.AddIndexColumn(#"Changed Type1", "Index", 1, 1, Int64.Type),
		    #"Removed Columns" = Table.RemoveColumns(#"Added Index",{"Index"})
		in
		    #"Removed Columns"
		```
	lineageTag: b479cbff-e3e6-4ff7-be32-d0a1c0a9f83b
	queryGroup: Silver

