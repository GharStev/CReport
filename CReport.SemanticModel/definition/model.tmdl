model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Parameters

	annotation PBI_QueryGroupOrder = 0

queryGroup DataSource

	annotation PBI_QueryGroupOrder = 1

queryGroup Silver

	annotation PBI_QueryGroupOrder = 2

queryGroup Dimensions

	annotation PBI_QueryGroupOrder = 3

queryGroup Surrogate_Keys

	annotation PBI_QueryGroupOrder = 4

queryGroup Facts

	annotation PBI_QueryGroupOrder = 5

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["CSVs","DataFolder","stg_Customer","stg_Employee","stg_Category","stg_Invoice","stg_Order","stg_OrderStatus","stg_OrderDetail","stg_Product","stg_Shipper","stg_Supplier","Shipment","Shipper","Customer","Employee","Product","Filters","Invoice","lkp_Customer_Key","lkp_OrderStatus_Key","lkp_Product_Key","lkp_Shipment_Key","lkp_Shipper_Key","Order"]

annotation PBI_ProTooling = ["DevMode"]

annotation __TEdtr = 1

ref table Date
ref table Shipper
ref table Customer
ref table Employee
ref table Product
ref table Shipment
ref table Order
ref table Filters

ref cultureInfo en-US

